# Xenforo data
.data/
xenforo/data/
xenforo/internal_data/

# Pointshop build output (generated by npm run build, baked into Docker image at deploy time)
xenforo/pointshop/

# Configs
.env
.env.*
!*.example

# Logs
*.log
nginx/logs/

# Wayback scrape output
wayback_out/
wayback_raw/
xenforo/scripts/wayback_out/
xenforo/scripts/wayback_raw/

# Database dumps (schema migrations live in mariadb/flyway/ and mariadb/initdb/ subdirs and are NOT matched here)
mariadb/dumps/
mariadb/*.sql
mariadb/*.sql~
mariadb/*.sql.gz
mariadb/*.dump

# Editors
.DS_Store
Thumbs.db
.idea/
.vscode/
